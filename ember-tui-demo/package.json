{
	"name": "ember-tui-demo",
	"version": "0.1.0",
	"description": "Demo application for ember-tui",
	"private": true,
	"scripts": {
		"start": "NODE_ENV=development node --inspect=9231 --enable-source-maps --loader ./loader.mjs app/app.ts",
		"dev": "rollup -c -w",
		"build": "rollup -c",
		"lint": "concurrently 'pnpm:lint:*(!fix)' --names 'lint:'",
		"lint:fix": "concurrently 'pnpm:lint:*:fix' --names 'fix:'",
		"lint:js": "eslint .",
		"lint:js:fix": "eslint . --fix",
		"lint:types": "ember-tsc --noEmit",
		"prebuild": "EMBROIDER_PREBUILD=true pnpm ember build",
		"test": "FORCE_COLOR=2 vitest --run --no-file-parallelism ./tests",
		"test:update": "vitest --run --update",
		"inspect": "ember-inspector-server"
	},
	"exports": {
		"./*": "./app/*",
		"./tests/*": "./tests/*"
	},
	"dependencies": {
		"@babel/runtime": "^7.29.2",
		"@glimmer/component": "^2.0.0",
		"chalk": "^5.3.0",
		"ember-inspector": "github:emberjs/ember-inspector#main",
		"ember-load-initializers": "^3.0.1",
		"ember-native-devtools": "^3.0.1",
		"ember-resolver": "^13.2.0",
		"ember-source": "^6.11.0",
		"ember-tui": "link:../ember-tui",
		"ember-vite-hmr": "^2.0.7",
		"yoga-layout": "~3.2.1"
	},
	"devDependencies": {
		"@babel/core": "^7.28.5",
		"@babel/eslint-parser": "^7.28.5",
		"@babel/plugin-proposal-class-properties": "^7.18.6",
		"@babel/plugin-proposal-decorators": "^7.29.0",
		"@babel/plugin-transform-runtime": "^7.29.0",
		"@babel/plugin-transform-typescript": "^7.23.0",
		"@ember/test-helpers": "^5.4.1",
		"@embroider/compat": "^4.1.17",
		"@embroider/core": "^4.4.7",
		"@embroider/legacy-inspector-support": "^0.1.3",
		"@embroider/macros": "^1.20.2",
		"@embroider/vite": "^1.7.1",
		"@eslint/js": "^9.28.0",
		"@glint/ember-tsc": "^1.0.8",
		"@glint/template": "^1.7.3",
		"@glint/tsserver-plugin": "^2.0.8",
		"@rollup/plugin-babel": "^6.0.4",
		"@rollup/plugin-commonjs": "^29.0.0",
		"@rollup/plugin-json": "^6.1.0",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@types/node": "^25.0.2",
		"@typescript-eslint/eslint-plugin": "^8.48.1",
		"@typescript-eslint/parser": "^8.50.0",
		"babel-plugin-ember-template-compilation": "^4.0.0",
		"concurrently": "^9.2.1",
		"content-tag": "^4.1.1",
		"decorator-transforms": "^2.0.0",
		"ember-cli": "^6.8.0",
		"ember-compatibility-helpers": "^1.2.7",
		"ember-vitest": "^0.3.3",
		"eslint": "^9.27.0",
		"eslint-config-airbnb-base": "^15.0.0",
		"eslint-config-prettier": "9.1.2",
		"eslint-plugin-ember": "^12.3.1",
		"eslint-plugin-ember-template-lint": "^0.21.0",
		"eslint-plugin-n": "^17.21.3",
		"eslint-plugin-node": "^11.1.0",
		"eslint-plugin-qunit": "^8.2.6",
		"fix-bad-declaration-output": "^1.1.4",
		"globals": "^16.5.0",
		"gradient-string": "^3.0.0",
		"indent-string": "^5.0.0",
		"jimp": "^1.6.0",
		"node-pty": "^1.1.0",
		"rollup": "^4.60.2",
		"strip-ansi": "^7.2.0",
		"tsx": "^4.7.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.1",
		"vite": "^7.2.7",
		"vitest": "^4.0.17"
	},
	"ember": {
		"edition": "octane"
	}
}
